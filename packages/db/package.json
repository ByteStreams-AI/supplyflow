{
  "name": "@supplyflow/db",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./schema": {
      "import": "./dist/schema/index.js",
      "types": "./dist/schema/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@supplyflow/types": "workspace:*",
    "drizzle-orm": "^0.43.1",
    "@supabase/supabase-js": "^2.50.0"
  },
  "devDependencies": {
    "typescript": "*",
    "drizzle-kit": "^0.31.1",
    "pg": "^8.14.1",
    "@types/pg": "^8.11.14"
  }
}
